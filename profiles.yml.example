# Copy to ~/.dbt/profiles.yml and fill in your project details.
# Values are pulled from environment variables so no secrets live in this file.
#
#   export DBT_GCP_PROJECT=my-gcp-project
#   export DBT_BQ_DATASET=analytics
#   export DBT_GCP_KEYFILE=/path/to/service-account.json

bigstar:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('DBT_GCP_PROJECT') }}"
      dataset: "{{ env_var('DBT_BQ_DATASET', 'analytics') }}"
      keyfile: "{{ env_var('DBT_GCP_KEYFILE') }}"
      location: US
      threads: 4
      timeout_seconds: 300
      priority: interactive
